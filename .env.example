# Copy this file to .env and fill in real values. Never commit .env (it's
# already in .gitignore).

# --- Database (Supabase) ---
# In Supabase: Project Settings → Database → Connection string → "URI".
# Use the *pooled* connection (port 6543, "Transaction" mode) for the app
# server — it's the one designed for many short-lived serverless-style
# connections, which is what an Express app doing per-request queries needs.
# Use the *direct* connection (port 5432) only for one-off scripts like
# `drizzle-kit migrate` or seed-db.mjs.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres"

# --- Admin panel auth (self-contained, no third-party auth provider) ---
# Username for the admin panel. Defaults to "admin" if not set.
ADMIN_USERNAME="admin"
# Never put a plaintext password here. Generate this with:
#   node scripts/hash-password.mjs "tu-contraseña-elegida"
# and paste the output below.
ADMIN_PASSWORD_HASH=""
# Secret used to sign the admin session token. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

NODE_ENV="development"
PORT="3000"
